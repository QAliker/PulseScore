generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Match {
  id         String      @id @default(cuid())
  externalId String?     @unique @map("external_id")
  homeTeam   String      @map("home_team")
  awayTeam   String      @map("away_team")
  homeScore  Int         @default(0) @map("home_score")
  awayScore  Int         @default(0) @map("away_score")
  status     MatchStatus @default(SCHEDULED)
  sport      String
  league     String?
  leagueId   String?     @map("league_id")
  leagueRel  League?     @relation(fields: [leagueId], references: [id])
  startTime  DateTime    @map("start_time")
  endTime    DateTime?   @map("end_time")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  events     MatchEvent[]

  @@index([status])
  @@index([startTime])
  @@map("matches")
}

model League {
  id         String   @id @default(cuid())
  externalId String   @unique @map("external_id")
  name       String
  sport      String
  country    String?
  logo       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  matches    Match[]
  standings  Standing[]

  @@map("leagues")
}

model Team {
  id         String   @id @default(cuid())
  externalId String   @unique @map("external_id")
  name       String
  shortName  String?  @map("short_name")
  logo       String?
  country    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  standings Standing[]
  players   Player[]

  @@map("teams")
}

model Standing {
  id           String   @id @default(cuid())
  leagueId     String   @map("league_id")
  league       League   @relation(fields: [leagueId], references: [id])
  teamId       String   @map("team_id")
  team         Team     @relation(fields: [teamId], references: [id])
  position     Int
  played       Int      @default(0)
  won          Int      @default(0)
  drawn        Int      @default(0)
  lost         Int      @default(0)
  goalsFor     Int      @default(0) @map("goals_for")
  goalsAgainst Int      @default(0) @map("goals_against")
  points       Int      @default(0)
  season       String
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([leagueId, teamId, season])
  @@map("standings")
}

model Player {
  id            String   @id @default(cuid())
  externalId    String   @unique @map("external_id")
  name          String
  image         String?
  number        Int?
  position      String?
  age           Int?
  teamId        String?  @map("team_id")
  team          Team?    @relation(fields: [teamId], references: [id])
  goals         Int      @default(0)
  assists       Int      @default(0)
  yellowCards   Int      @default(0) @map("yellow_cards")
  redCards      Int      @default(0) @map("red_cards")
  matchesPlayed Int      @default(0) @map("matches_played")
  rating        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("players")
}

model MatchEvent {
  id        String         @id @default(cuid())
  matchId   String         @map("match_id")
  match     Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      MatchEventType
  minute    Int?
  player    String?
  team      String?
  detail    String?
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([matchId])
  @@map("match_events")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
  POSTPONED
}

enum MatchEventType {
  GOAL
  OWN_GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  HALFTIME
  FULLTIME
  PENALTY_GOAL
  PENALTY_MISS
}
